# Production build: consume the real backend instead of in-memory mocks.
VITE_USE_MOCKS=false

# Absolute base URL of the API, INCLUDING the /api prefix, e.g.:
#   VITE_API_URL=https://omni-campaign-studio-api.vercel.app/api
# Set it here, in an untracked .env.production.local, or as a build-time env var
# on your host (Vercel/Netlify). If left unset the app falls back to the relative
# "/api" path, which only works when the API is served from the same origin.
# VITE_API_URL=
