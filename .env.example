# Base URL of the API, including the /api prefix.
# - Same-origin deploy: keep "/api".
# - Separate host: use an absolute URL, e.g. https://your-api.vercel.app/api
VITE_API_URL=/api

# 'true'  -> serve all data from local in-memory fixtures (no backend needed)
# 'false' -> consume the real REST API at VITE_API_URL
VITE_USE_MOCKS=false
# API key issued by omni-campaign-studio-gateway. Sent as `Authorization: Bearer`
# on every request. Leave empty when talking to an unauthenticated API directly.
VITE_API_KEY=
