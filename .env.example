# Base URL of the API, including the /api prefix.
# - Same-origin deploy: keep "/api".
# - Separate host: use an absolute URL, e.g. https://your-api.vercel.app/api
VITE_API_URL=/api

# 'true'  -> serve all data from local in-memory fixtures (no backend needed)
# 'false' -> consume the real REST API at VITE_API_URL
VITE_USE_MOCKS=false
# Gateway origin (root, NOT including /api) for the login/refresh endpoints
# (/_gw/auth/*). If empty, it is derived from VITE_API_URL by dropping "/api".
VITE_GATEWAY_URL=

# Optional static API key for server-to-server / dev. The browser normally signs
# in via the gateway login instead; the user's access token takes precedence.
VITE_API_KEY=
